{
  "compilerOptions": {
    "target": "es2015",
    "lib": [
      "es6"
    ],
    "types": [
      "node",
      "jest"
    ],
    "rootDir": "src",
    "outDir": "dist",
    "module": "commonjs",
    "moduleResolution": "node",
    "sourceMap": true,
    "declaration": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "esModuleInterop": false,
    "skipLibCheck": true,
  },
  "include": ["src"],
  "exclude": ["__test__"]
}